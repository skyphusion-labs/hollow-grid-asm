# Basalt Relay runtime configuration.
# Copy to .env for local runs; fleet uses /opt/stacks/basalt-relay/.env on biafra.

WORLD_NAME=Basalt Relay
LISTEN_ADDR=0.0.0.0:8793

# Public WebSocket URL advertised for federation travel.
WORLD_URL=wss://basalt.skyphusion.org/ws

# Leave both unset for standalone operation.
GRID_HUB_URL=https://grid-hub.skyphusion.org/rpc
GRID_HUB_TOKEN=

# Local persistence path and comma-separated keeper names.
DATA_DIR=./data
ADMINS=skyphusion
# ADMIN_TOKEN=   # required for keeper-name login (shared Grid token)
